{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Bihari AI application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was first created." }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a user and the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the chat." },
        "userId": { "type": "string", "description": "The ID of the user who owns this chat." },
        "title": { "type": "string", "description": "The title of the conversation." },
        "createdAt": { "type": "number", "description": "Timestamp when the chat was created." },
        "updatedAt": { "type": "number", "description": "Timestamp when the chat was last updated." }
      },
      "required": ["id", "userId", "title", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message." },
        "parts": { "type": "array", "items": { "type": "object" }, "description": "The content of the message." },
        "createdAt": { "type": "number", "description": "Timestamp when the message was sent." }
      },
      "required": ["role", "parts", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "A user's chat conversations."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat."
    }
  }
}
